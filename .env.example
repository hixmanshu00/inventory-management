# Root env for docker compose. Copy to .env: `cp .env.example .env`
# The real .env is gitignored — change the password before any real deployment.

# --- Database ---
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory
POSTGRES_DB=inventory

# --- Host ports ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Backend ---
# Must include the frontend's origin below so the browser can call the API.
CORS_ORIGINS=http://localhost:5173
LOW_STOCK_THRESHOLD=10
# Seed a few products/customers on first start so the app isn't empty.
SEED_ON_START=true

# --- Frontend (build-time) ---
# Browser-reachable backend URL; matches BACKEND_PORT above.
VITE_API_URL=http://localhost:8000
