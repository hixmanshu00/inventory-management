# Copy to .env and adjust. Never commit the real .env.

# --- Database ---
# Full SQLAlchemy URL. psycopg (v3) driver.
DATABASE_URL=postgresql+psycopg://inventory:inventory@localhost:5432/inventory

# --- App ---
# Comma-separated list of allowed CORS origins (no wildcard in prod).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Products at or below this stock level are reported as "low stock" on the dashboard.
LOW_STOCK_THRESHOLD=10
